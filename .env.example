# ============================================================
# Real-Time Voice Customer Support Agent — Environment Config
# ============================================================
# Copy this to .env and fill in your actual keys before running.

# --- OpenAI (used for LLM completions + optional embeddings) ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Deepgram (primary STT provider) ---
DEEPGRAM_API_KEY=your-deepgram-api-key

# --- ElevenLabs (primary TTS provider) ---
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Twilio (telephony) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# --- Vector Store ---
VECTOR_STORE_TYPE=faiss
VECTOR_STORE_PATH=./data/vector_index
EMBEDDING_DIMENSION=1536

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Agent Thresholds ---
CONFIDENCE_THRESHOLD=0.65
MAX_RETRIEVAL_RESULTS=5
ESCALATION_KEYWORDS=manager,human,supervisor,representative,person

# --- Audio ---
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_MS=100
